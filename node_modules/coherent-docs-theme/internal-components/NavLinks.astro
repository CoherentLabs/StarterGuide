---
import getThemeConfig from "../internal/themeConfig";
import { Icon } from "@astrojs/starlight/components";

interface Props {
    type?: "header" | "sidebar";
}

const { type = "header" } = Astro.props;
const { navLinks, documentationSearchTag } = getThemeConfig();

const isLinkActive = (
    href: string,
    label: string,
    subDocumentations?: string[],
) => {
    try {
        const lowerLabel = label.toLocaleLowerCase();
        const searchTag = documentationSearchTag?.toLocaleLowerCase();

        if (searchTag) {
            if (searchTag === lowerLabel) return true;

            if (subDocumentations && subDocumentations.length > 0) {
                const possibleTags = subDocumentations.map(
                    (sub) => `${lowerLabel} ${sub.toLocaleLowerCase()}`,
                );
                if (possibleTags.includes(searchTag)) {
                    return true;
                }
            }
        }

        const linkUrl = new URL(href, Astro.url.origin);
        const currentUrl = Astro.url;
        const isLocal =
            currentUrl.hostname === "localhost" ||
            currentUrl.hostname === "127.0.0.1";

        const normalize = (p: string) => p.replace(/\/+$/, "") || "/";
        const currentPath = normalize(currentUrl.pathname);
        const linkPath = normalize(linkUrl.pathname);

        if (isLocal) return lowerLabel === searchTag;
        if (linkUrl.origin !== currentUrl.origin) return false;
        if (linkPath === "/") return true;

        return (
            currentPath === linkPath || currentPath.startsWith(linkPath + "/")
        );
    } catch (e) {
        return false;
    }
};

const navClasses =
    type === "header"
        ? "extra-links sl-hidden md:sl-flex"
        : "extra-links mobile sidebar-mode lg:hidden";

const activeLinkObj = navLinks?.find((link) =>
    isLinkActive(link.href, link.label, link.subDocumentations),
);
const activeLabel = activeLinkObj ? activeLinkObj.label : "Documentations";
---

{
    navLinks && navLinks.length > 0 && (
        <>
            <nav
                class={"smart-nav " + navClasses}
                id="smart-nav"
                aria-label="Global Navigation"
            >
                {type === "header" && (
                    <div class="vertical-separator md:sl-flex" />
                )}

                <ul class="full-nav-list">
                    {navLinks.map((link) => (
                        <li class="nav-item">
                            <a
                                href={link.href}
                                class={`nav-link ${isLinkActive(link.href, link.label, link.subDocumentations) ? "active" : ""}`}
                            >
                                {link.label}
                            </a>
                        </li>
                    ))}
                </ul>

                <div class="collapsed-menu" style="display: none;">
                    <button class="dropdown-btn" aria-expanded="false">
                        <span class="btn-text">{activeLabel}</span>
                        <Icon name="down-caret" size="0.75rem" />
                    </button>

                    <ul class="dropdown-list">
                        {navLinks.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class={`dropdown-link ${isLinkActive(link.href, link.label, link.subDocumentations) ? "active" : ""}`}
                                >
                                    {link.label}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            </nav>
        </>
    )
}

<style>
    .smart-nav {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
    }

    .vertical-separator {
        width: 1px;
        height: 1.5rem;
        margin-right: 1rem;
        background-color: var(--sl-color-gray-5);
    }

    .full-nav-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 1.5rem;
        align-items: center;
        white-space: nowrap;
    }

    .nav-link {
        position: relative;
        color: var(--sl-color-gray-3);
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        display: block;
        padding: 0.5rem 0;
        transition: color 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nav-link::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background-color: var(--sl-color-accent);
        transform: scaleX(0);
        transform-origin: center;
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nav-link:hover,
    .nav-link.active {
        color: var(--sl-color-accent);
    }

    .nav-link:hover::after,
    .nav-link.active::after {
        transform: scaleX(1);
        transform-origin: center;
    }

    .nav-link.active {
        color: var(--sl-color-white);
    }

    .collapsed-menu {
        position: relative;
    }

    .dropdown-btn {
        background: transparent;
        border: 1px solid var(--sl-color-gray-5);
        color: var(--sl-color-gray-3);
        cursor: pointer;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.35rem 0.75rem;
        border-radius: 4px;
        white-space: nowrap;
    }

    .dropdown-btn:hover {
        border-color: var(--sl-color-gray-2);
        color: var(--sl-color-white);
    }

    .collapsed-menu.has-active .dropdown-btn {
        color: var(--sl-color-accent);
        border-color: var(--sl-color-accent);
        background: rgba(var(--sl-color-accent-rgb), 0.1);
    }

    .dropdown-list {
        position: absolute;
        top: 100%;
        left: 0;
        background-color: var(--sl-color-bg-nav);
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.5rem;
        box-shadow: var(--sl-shadow-lg);
        padding: 0.5rem 0;
        list-style: none;
        display: none;
        flex-direction: column;
        min-width: 200px;
        z-index: 9999;
    }
    .collapsed-menu:hover .dropdown-list {
        display: flex;
    }

    .dropdown-link {
        display: block;
        padding: 0.75rem 1.5rem;
        color: var(--sl-color-gray-3);
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .dropdown-link:hover,
    .dropdown-link.active {
        background-color: rgba(var(--sl-color-accent-rgb), 0.1);
        color: var(--sl-color-accent);
        padding-left: 1.75rem;
    }
</style>

<script>
    class SmartNav {
        container: HTMLElement;
        verticalSeparator: HTMLElement | null;
        fullList: HTMLElement;
        collapsedMenu: HTMLElement;
        fullListWidth: number;

        constructor(navElement: HTMLElement) {
            this.container = navElement;
            this.verticalSeparator = navElement.querySelector(
                ".vertical-separator",
            ) as HTMLElement;
            this.fullList = navElement.querySelector(
                ".full-nav-list",
            ) as HTMLElement;
            this.collapsedMenu = navElement.querySelector(
                ".collapsed-menu",
            ) as HTMLElement;

            this.fullListWidth = this.calculateRequiredWidth();

            if (this.fullList.querySelector(".active")) {
                this.collapsedMenu.classList.add("has-active");
            }

            this.check();

            const observer = new ResizeObserver(() => {
                requestAnimationFrame(() => this.check());
            });
            observer.observe(this.container);
        }

        calculateRequiredWidth() {
            const items = Array.from(this.fullList.children) as HTMLElement[];
            if (items.length === 0) return 0;

            let totalWidth = 0;
            items.forEach((item) => {
                totalWidth += item.getBoundingClientRect().width;
            });

            const gap = 24;
            totalWidth += (items.length - 1) * gap;

            return totalWidth + 10;
        }

        check() {
            const availableWidth = this.container.getBoundingClientRect().width;

            if (availableWidth === 0) return;

            if (availableWidth < this.fullListWidth) {
                if (this.verticalSeparator)
                    this.verticalSeparator.style.display = "none";
                this.container.style.flexDirection = "row-reverse";
                this.fullList.style.display = "none";
                this.collapsedMenu.style.display = "block";
            } else {
                if (this.verticalSeparator)
                    this.verticalSeparator.style.display = "block";
                this.container.style.flexDirection = "row";
                this.fullList.style.display = "flex";
                this.collapsedMenu.style.display = "none";
            }
        }
    }

    const init = () => {
        const nav = document.getElementById("smart-nav");
        if (nav) new SmartNav(nav);
    };

    document.addEventListener("astro:page-load", init);
    document.addEventListener("DOMContentLoaded", init);
</script>
