---
interface Topic {
  id: string;
  label: string;
  href: string;
  icon: any;
}

interface Props {
  topics: Topic[];
  currentTopicId?: string | undefined;
  version?: string | undefined;
}

const { topics, currentTopicId, version } = Astro.props;
const isCurrent = (id: string) => id === currentTopicId;
const hasContent = topics.length > 0 || version;
---

{
  hasContent && (
    <>
      {version && (
        <div class="version-badge">
          <span>Version:</span>
          <span class="sl-badge tip small">{version}</span>
        </div>
      )}
      <div class="topics-wrapper">
        <ul class="starlight-sidebar-topics">
          {topics.map((topic) => {
            const iconUrl =
              typeof topic.icon === "object" ? topic.icon.src : topic.icon;
            const isImage =
              iconUrl &&
              (iconUrl.startsWith("/") ||
                iconUrl.startsWith("http") ||
                iconUrl.startsWith("data:"));

            return (
              <li>
                <a
                  href={topic.href}
                  class:list={{
                    "starlight-sidebar-topics-current": isCurrent(topic.id),
                  }}
                >
                  <div class="starlight-sidebar-topics-icon">
                    {isImage ? (
                      <div
                        class="icon-mask"
                        style={`--icon-url: url('${iconUrl}')`}
                        role="img"
                        aria-label={topic.label}
                      />
                    ) : (
                      <span class="text-icon">{topic.icon}</span>
                    )}
                  </div>
                  <div class="label-wrapper">{topic.label}</div>
                </a>
              </li>
            );
          })}
        </ul>
        <div class="sidebar-divider" />
      </div>
    </>
  )
}

<style>
  .starlight-sidebar-topics {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li + li {
    margin-top: 0.25rem;
  }

  a {
    align-items: center;
    color: var(--sl-color-gray-2);
    display: flex;
    font-size: 0.85rem;
    font-weight: 700;
    gap: 0.6rem;
    text-decoration: none;
    border-radius: 0.25rem;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  a:hover,
  a:focus-visible {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-5);
  }

  a.starlight-sidebar-topics-current {
    color: var(--gameface-cyan);
    background-color: var(--sl-color-gray-5);
  }

  .starlight-sidebar-topics-icon {
    align-items: center;
    border-radius: 0.25rem;
    display: flex;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .icon-mask {
    width: 100%;
    height: 100%;

    -webkit-mask-image: var(--icon-url);
    mask-image: var(--icon-url);

    -webkit-mask-size: contain;
    mask-size: cover;

    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;

    -webkit-mask-position: center;
    mask-position: center;

    background-color: var(--sl-color-gray-2);
    transition: background-color 0.2s ease;
  }

  a:hover .icon-mask,
  a:focus-visible .icon-mask {
    background-color: var(--sl-color-white);
  }

  a.starlight-sidebar-topics-current .icon-mask {
    background-color: var(--gameface-cyan);
  }

  :global([data-theme="light"]) a.starlight-sidebar-topics-current {
    color: var(--sl-color-accent-high);
  }
  :global([data-theme="light"]) a.starlight-sidebar-topics-current .icon-mask {
    background-color: var(--sl-color-accent-high);
  }

  .text-icon {
    font-size: 0.65rem;
    font-weight: 800;
  }

  .version-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.2rem 0.5rem;
    background-color: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.3rem;
    color: var(--sl-color-gray-2);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .sidebar-divider {
    margin-top: 1rem;
    height: 1px;
    border-top: 1px solid var(--sl-color-gray-5);
  }

  .label-wrapper {
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
</style>
