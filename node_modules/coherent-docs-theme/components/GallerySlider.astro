---
import fs from "node:fs";
import path from "node:path";
import { Icon } from "@astrojs/starlight/components";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type CustomSlide = {
    src: string | ImageMetadata;
    link?: string;
    description?: string;
    alt?: string;
};

type GalleryItem = string | ImageMetadata | CustomSlide;

interface Props {
    dir?: string;
    images?: GalleryItem[];
    width?: string;
    height?: string;
    autoSlide?: number;
}

let {
    dir,
    images = [],
    width = "100%",
    height = "300px",
    autoSlide = 0,
} = Astro.props;

let slides: CustomSlide[] = [];
const baseUrl =
    import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL;

const resolveUrl = (srcPath: string) => {
    if (srcPath.startsWith("/") && !srcPath.startsWith("//")) {
        const cleanBase = baseUrl.replace(/\/+$/, "");
        if (cleanBase && !srcPath.startsWith(cleanBase)) {
            return `${cleanBase}${srcPath}`;
        }
    }
    return srcPath;
};

if (dir) {
    const cleanDir = dir.replace(/\/+$/, "");
    const publicPath = path.join(process.cwd(), "public", cleanDir);

    try {
        if (fs.existsSync(publicPath)) {
            const files = fs.readdirSync(publicPath);
            const imageFiles = files.filter((file) =>
                /\.(png|jpe?g|gif|svg|webp)$/i.test(file),
            );
            slides.push(
                ...imageFiles.map((file) => ({
                    src: resolveUrl(`/${cleanDir}/${file}`),
                })),
            );
        }
    } catch (e) {
        console.error(
            `[Gallery] Error while reading the dir: ${publicPath}`,
            e,
        );
    }
}

images.forEach((item: any) => {
    if (typeof item === "string") {
        slides.push({ src: resolveUrl(item) });
    } else if (
        item.format !== undefined &&
        item.width !== undefined &&
        item.height !== undefined &&
        item.description === undefined
    ) {
        slides.push({ src: item as ImageMetadata });
    } else {
        const customSlide = { ...item } as CustomSlide;
        
        if (typeof customSlide.src === "string") {
            customSlide.src = resolveUrl(customSlide.src);
        }
        
        slides.push(customSlide);
    }
});

if (slides.length === 0) {
    console.warn("[Gallery] No images found.");
}
---

<gallery-slider data-auto-slide={autoSlide}>
    <div class="slide-window" style={`width: ${width}; height: ${height};`}>
        <ul class="slides-list">
            {
                slides.map((slide) => {
                    const isLocal = typeof slide.src === "object";
                    const altText = slide.alt || "Gallery slide";

                    const imgContent = isLocal ? (
                        <Image
                            src={slide.src as ImageMetadata}
                            alt={altText}
                            class="slide-img"
                        />
                    ) : (
                        <img
                            src={slide.src as string}
                            alt={altText}
                            class="slide-img"
                        />
                    );

                    const slideBody = slide.link ? (
                        <a
                            href={slide.link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="slide-link"
                        >
                            {imgContent}
                        </a>
                    ) : (
                        imgContent
                    );

                    return (
                        <li class="slide">
                            {slideBody}

                            {slide.description && (
                                <div class="slide-caption">
                                    <p>{slide.description}</p>
                                </div>
                            )}
                        </li>
                    );
                })
            }
        </ul>

        <button class="nav left" aria-label="Previous image">
            <Icon name="left-arrow" size="2rem" />
        </button>
        <button class="nav right" aria-label="Next image">
            <Icon name="right-arrow" size="2rem" />
        </button>
    </div>
</gallery-slider>

<style>
    gallery-slider {
        display: block;
        margin: 2rem auto;
        max-width: 100%;
    }

    .slide-window {
        position: relative;
        overflow: hidden;
        border-radius: 8px;
        box-shadow: var(--sl-shadow-md);
        background-color: var(--sl-color-gray-6);
    }

    .slides-list {
        display: flex;
        width: 100%;
        height: 100%;
        margin: 0 !important;
        padding: 0 !important;
        list-style: none !important;
        transition: transform 0.5s ease-in-out;
    }

    .slide {
        flex: 0 0 100%;
        height: 100%;
        position: relative;
    }

    .slide-link {
        display: block;
        width: 100%;
        height: 100%;
    }

    .slide-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
        user-select: none;
        margin-bottom: 0 !important;
    }

    .slide-caption {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        background-color: rgba(0, 0, 0, 0.75);
        color: white;
        padding: 1rem 1.5rem;
        text-align: center;
        box-sizing: border-box;
        pointer-events: none;
    }

    .slide-caption p {
        margin: 0 !important;
        font-size: 0.95rem;
        line-height: 1.4;
    }

    .nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0, 0, 0, 0.5);
        color: white;
        border: none;
        border-radius: 50%;
        width: 3rem;
        height: 3rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 10;
        transition: background 0.2s ease;
    }

    .nav:hover {
        background: rgba(0, 0, 0, 0.9);
    }

    .nav.left {
        left: 1rem;
    }
    .nav.right {
        right: 1rem;
    }
</style>

<script>
    class GallerySlider extends HTMLElement {
        currentSlide: number = 0;
        slidesList: HTMLElement | undefined;
        slides: NodeListOf<Element> | undefined;
        totalSlides: number = 0;
        autoSlide: number = 0;
        interval: NodeJS.Timeout | null = null;

        connectedCallback() {
            this.currentSlide = 0;
            this.slidesList = this.querySelector(".slides-list") as HTMLElement;
            this.slides = this.querySelectorAll(".slide");
            this.totalSlides = this.slides.length;
            this.autoSlide = parseInt(this.dataset.autoSlide || "0", 10);
            this.interval = null;

            if (this.totalSlides === 0) return;

            this.querySelector(".left")?.addEventListener("click", () =>
                this.move("back"),
            );
            this.querySelector(".right")?.addEventListener("click", () =>
                this.move("forward"),
            );

            this.resetAutoSlide();
        }

        move(direction: "back" | "forward") {
            if (direction === "back") {
                this.currentSlide =
                    (this.currentSlide - 1 + this.totalSlides) %
                    this.totalSlides;
            } else {
                this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
            }
            this.updateDOM();
            this.resetAutoSlide();
        }

        updateDOM() {
            if (this.slidesList)
                this.slidesList.style.transform = `translateX(-${this.currentSlide * 100}%)`;
        }

        resetAutoSlide() {
            if (this.autoSlide > 0) {
                if (this.interval) clearInterval(this.interval);
                this.interval = setInterval(
                    () => this.move("forward"),
                    this.autoSlide,
                ) as any;
            }
        }
    }

    if (!customElements.get("gallery-slider")) {
        customElements.define("gallery-slider", GallerySlider);
    }
</script>
