---
import ChangelogRow, {
    type ChangelogProps,
} from "../internal-components/ChangelogRow.astro";

interface Props extends ChangelogProps {}

const { engine, description } = Astro.props;
---

{
    Astro.slots.has("default") ? (
        <ChangelogRow
            badgeText="API"
            badgeVariant="note"
            engine={engine}
            description={description}
        >
            <slot />
        </ChangelogRow>
    ) : (
        <ChangelogRow
            badgeText="API"
            badgeVariant="note"
            engine={engine}
            description={description}
        />
    )
}
