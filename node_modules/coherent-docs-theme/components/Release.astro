---
interface Props {
    date: string;
    version: string;
}

const { date } = Astro.props;
---

<div class="release-container">
    <hr />
    <div class="release-date">
        <a
            href="https://coherent-labs.com/get-in-touch/"
            target="_blank"
            rel="noopener noreferrer"
        >
            <span>Released {date}</span>
        </a>
    </div>

    <div class="table-wrapper">
        <table class="table table-striped">
            <tbody>
                <slot />
            </tbody>
        </table>
    </div>
</div>

<style>
    .release-container {
        margin-bottom: 2rem;
    }

    .release-date {
        margin-bottom: 1.5rem;
        font-size: 0.95rem;
    }

    .table-striped {
        width: 100%;
        border-collapse: collapse;
    }

    .table-wrapper :global(.table-striped td:first-child),
    .table-wrapper :global(.table-striped th:first-child) {
        padding-inline-start: 1rem !important;
        vertical-align: top;
        padding-block: 1rem;

        width: 22%;
        min-width: 145px;
        white-space: normal;
    }

    .table-wrapper :global(.table-striped td:last-child) {
        padding-inline-end: 1rem !important;
    }

    .table-wrapper :global(.table-striped td:first-child > *) {
        display: inline-block;
        margin-right: 0.4rem;
        margin-bottom: 0.4rem;
    }

    @media (max-width: 1000px) {
        .table-wrapper :global(.table-striped),
        .table-wrapper :global(.table-striped tbody),
        .table-wrapper :global(.table-striped tr),
        .table-wrapper :global(.table-striped td) {
            display: block;
            width: 100%;
        }

        .table-wrapper :global(.table-striped td:first-child),
        .table-wrapper :global(.table-striped th:first-child) {
            width: 100%;
        }

        .table-wrapper :global(.table-striped tr) {
            padding: 1rem 0;
            border-bottom: 1px solid var(--sl-color-gray-5);
        }

        .table-wrapper :global(.table-striped td:last-child) {
            border-bottom: none;
        }

        .table-wrapper :global(.table-striped td:first-child) {
            padding-block: 0 !important;
            padding-bottom: 0.5rem !important;
            border: none;
        }

        .table-wrapper :global(.table-striped td:last-child) {
            padding-block: 0 !important;
        }
    }
</style>
