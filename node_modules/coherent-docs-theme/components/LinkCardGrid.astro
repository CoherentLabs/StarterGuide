---
import { Card, CardGrid } from '@astrojs/starlight/components';

export interface Props {
  cards: {
    href: string;
    title: string;
    imgSrc: string;
    description: string;
  }[];
}

const { cards } = Astro.props;
const currentProduct = import.meta.env.DOCS_PRODUCT || "Gameface";
const productName =
    currentProduct.charAt(0).toUpperCase() + currentProduct.slice(1);

cards.forEach((card) => {
  card.title = card.title.replace(
        /<ProductName\s*\/?>|<ProductName>\s*<\/ProductName>/gi,
        productName,
  )
  card.description = card.description.replace(
        /<ProductName\s*\/?>|<ProductName>\s*<\/ProductName>/gi,
        productName,
  )
});
---

<CardGrid class="custom-card-grid">
  {cards.map((card) => (
    <a class="card-link" href={card.href}>
      <Card title={card.title}>
        <img src={card.imgSrc} class="card-image" alt={card.title} />
        <p>{card.description}</p>
      </Card>
    </a>
  ))}
</CardGrid>

<style>
  .custom-card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  @media (max-width: 90rem) {
    .custom-card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
  }

  @media (max-width: 70rem) {
    .custom-card-grid {
      grid-template-columns: 1fr !important;
    }
  }

  .card-link {
    text-decoration: none;
    position: relative;
  }

  .card-link p {
    color: var(--sl-color-text);
  }

  .card-image {
    width: 100%;
    height: 10rem;
    object-fit: cover;
    object-position: top center;
    margin-bottom: 1rem;
  }
</style>