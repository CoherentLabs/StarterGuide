---
import DefaultSidebar from "@astrojs/starlight/components/Sidebar.astro";
import getThemeConfig from "../internal/themeConfig";
import TopicSwitcherUI from "../internal-components/TopicSwitcherUI.astro";
import nativeIcon from "../assets/icons/native.png";
import unrealIcon from "../assets/icons/unreal.png";
import unityIcon from "../assets/icons/unity.png";

const currentProduct = import.meta.env.DOCS_PRODUCT || "Gameface";
const productName =
    currentProduct.charAt(0).toUpperCase() + currentProduct.slice(1);
const productNameRegex =
    /<ProductName\s*\/?>|<ProductName>\s*<\/ProductName>/gi;

function formatSidebar(items: any[]) {
    if (!items) return;
    for (const item of items) {
        if (item.label) {
            item.label = item.label.replace(productNameRegex, productName);
        }
        if (item.type === "group" && item.entries) {
            formatSidebar(item.entries);
        }
    }
}

if (Astro.locals.starlightRoute?.sidebar) {
    const sidebarClone = JSON.parse(
        JSON.stringify(Astro.locals.starlightRoute.sidebar),
    );
    formatSidebar(sidebarClone);
    Astro.locals.starlightRoute.sidebar = sidebarClone;
}

const product = import.meta.env.DOCS_PRODUCT || "gameface";
const { topicsConfig, version, currentTopicId } = getThemeConfig();

const topics = {
    native: {
        label: "Custom Engine",
        href: `https://docs.coherent-labs.com/cpp-${product}`,
        icon: nativeIcon,
        ...(topicsConfig?.native || {}),
    },
    unreal: {
        label: "Unreal Engine",
        href: `https://docs.coherent-labs.com/unreal-${product}`,
        icon: unrealIcon,
        ...(topicsConfig?.unreal || {}),
    },
    unity: {
        label: "Unity 3D",
        href: `https://docs.coherent-labs.com/unity-${product}`,
        icon: unityIcon,
        ...(topicsConfig?.unity || {}),
    },
};

const topicsArray = Object.entries(topics).map(([id, data]) => ({
    id,
    ...data,
}));
---

<TopicSwitcherUI
    topics={topicsArray}
    currentTopicId={currentTopicId}
    version={version}
/>
<DefaultSidebar {...Astro.props} />
