---
import DocsLink from "../internal-components/DocsLink.astro";

export interface Props {
    href: string;
    product?: "gameface" | "prysm";
}

const { href, product } = Astro.props;

const currentProduct = product || process.env.DOCS_PRODUCT || "gameface";
---

<DocsLink href={href} product={currentProduct} type="unreal"><slot/></DocsLink>
