---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { imageRegistry } from "../utils/imageRegistry";

interface Props {
    src: string | ImageMetadata;
    alt?: string;
    caption?: string;
    title?: string;
    class?: string;
    link?: string;
    target?: string;
    rel?: string;
    width?: number | string;
    height?: number | string;
    attr?: string;
    attrlink?: string;
}

const {
    src,
    alt,
    caption,
    title,
    class: className,
    link,
    target,
    rel,
    width,
    height,
    attr,
    attrlink,
} = Astro.props;

const altText = alt || caption || "";

let isLocal = typeof src === "object";
let resolvedImage: ImageMetadata | string = src as any;
const baseUrl =
    import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL;

if (typeof src === "string") {
    if (src.startsWith("/") && !src.startsWith("//")) {
        let normalizedSrc = src;

        if (baseUrl && !src.startsWith(baseUrl)) {
            const cleanBase = baseUrl.replace(/\/+$/, "");
            normalizedSrc = `${cleanBase}${src}`;
        }

        resolvedImage = normalizedSrc;
        isLocal = false;
    } else if (!src.startsWith("http") && !src.startsWith("data:")) {
        const fileName = src.replace(/^\.\//, "").split("/").pop() || src;

        const importFn = imageRegistry.get(fileName);

        if (importFn) {
            resolvedImage = (await importFn()).default;
            isLocal = true;
        } else {
            console.warn(`[Figure] Image not found in registry: ${src}`);
            isLocal = false;
        }
    }
}

const Wrapper = link ? "a" : Fragment;

const wrapperProps = link
    ? { href: link, target, rel, class: "figure-link" }
    : {};
---

<figure class={className}>
    <Wrapper {...wrapperProps}>
        <div class="figure-img-wrapper">
            <div class="figure-spinner">
                <svg viewBox="0 0 50 50">
                    <circle
                        class="spinner-track"
                        cx="25"
                        cy="25"
                        r="20"
                        fill="none"
                        stroke-width="4"></circle>
                    <circle
                        class="spinner-head"
                        cx="25"
                        cy="25"
                        r="20"
                        fill="none"
                        stroke-width="4"></circle>
                </svg>
            </div>
            {
                isLocal ? (
                    <Image
                        src={resolvedImage as ImageMetadata}
                        alt={altText}
                        title={title}
                        width={width as any}
                        height={height as any}
                        class="figure-image"
                    />
                ) : (
                    <img
                        src={resolvedImage as string}
                        alt={altText}
                        title={title}
                        width={width}
                        height={height}
                        class="figure-image"
                    />
                )
            }
        </div>
    </Wrapper>

    {
        (caption || attr) && (
            <figcaption>
                {caption && <p>{caption}</p>}

                {attr && (
                    <p>{attrlink ? <a href={attrlink}>{attr}</a> : attr}</p>
                )}
            </figcaption>
        )
    }
</figure>

<script>
    function setupFigureLoaders() {
        const wrappers = document.querySelectorAll(".figure-img-wrapper");

        wrappers.forEach((wrapper) => {
            const img = wrapper.querySelector("img");
            if (!img) return;

            if (img.complete) {
                wrapper.classList.add("is-loaded");
            } else {
                img.addEventListener("load", () =>
                    wrapper.classList.add("is-loaded"),
                );
                img.addEventListener("error", () =>
                    wrapper.classList.add("is-loaded"),
                );
            }
        });
    }

    document.addEventListener("astro:page-load", setupFigureLoaders);
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupFigureLoaders);
    } else {
        setupFigureLoaders();
    }
</script>

<style>
    figure {
        margin: 2rem 0;
        text-align: center;
    }

    .figure-link {
        display: inline-block;
        text-decoration: none;
    }

    figcaption {
        margin-top: 0.5rem;
        font-size: 0.9rem;
        color: var(--sl-color-gray-3);
        text-align: start;
    }

    figcaption p {
        margin: 0;
    }

    .figure-img-wrapper {
        position: relative;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        min-height: 120px;
        min-width: 120px;
        background-color: var(--sl-color-gray-6);
        border-radius: 4px;
        overflow: hidden;
    }

    .figure-spinner {
        position: absolute;
        width: 36px;
        height: 36px;
        z-index: 1;
        animation: figure-spin 1s linear infinite;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .figure-spinner svg {
        width: 100%;
        height: 100%;
    }

    .spinner-track {
        stroke: var(--sl-color-gray-4);
    }

    .spinner-head {
        stroke: var(--sl-color-accent);
        stroke-dasharray: 30, 150;
        stroke-linecap: square;
    }

    @keyframes figure-spin {
        0% {
            transform: rotate(0deg);
        }
        100% {
            transform: rotate(360deg);
        }
    }

    .figure-image {
        position: relative;
        z-index: 2;
        opacity: 0;
        transition: opacity 0.3s ease-in-out;
        max-width: 100%;
        height: auto;
        display: block;
        margin: 0 !important;
    }

    .figure-img-wrapper.is-loaded .figure-spinner {
        display: none !important;
    }

    .figure-img-wrapper.is-loaded .figure-image {
        opacity: 1;
    }

    .figure-img-wrapper.is-loaded {
        background-color: transparent;
    }
</style>
