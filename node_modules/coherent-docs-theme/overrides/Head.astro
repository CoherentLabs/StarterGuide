---
import DefaultHead from '@astrojs/starlight/components/Head.astro';

const currentProduct = import.meta.env.DOCS_PRODUCT || "Gameface";
const productName = currentProduct.charAt(0).toUpperCase() + currentProduct.slice(1);

const productNameRegex = /<ProductName\s*\/?>|<ProductName>\s*<\/ProductName>/gi;

const routeData = Astro.locals.starlightRoute ?? Astro.props;

if (Array.isArray(routeData?.head)) {
    routeData.head.forEach((tag) => {
        if (tag.tag === 'title' && typeof tag.content === 'string') {
            tag.content = tag.content.replace(productNameRegex, productName);
        }

        if (tag.tag === 'meta' && typeof tag.attrs?.content === 'string') {
            const isTargetMeta = 
                tag.attrs.name === 'description' || 
                tag.attrs.property === 'og:title' || 
                tag.attrs.property === 'og:description' ||
                tag.attrs.name === 'twitter:title' ||
                tag.attrs.name === 'twitter:description';

            if (isTargetMeta) {
                tag.attrs.content = tag.attrs.content.replace(productNameRegex, productName);
            }
        }
    });
}
---

<DefaultHead {...Astro.props} />