<style>
    .aurora-glow {
        position: fixed;
        border-radius: 50%;
        width: 50vw;
        height: 50vw;
        max-width: 600px;
        max-height: 600px;
        filter: blur(120px);
        z-index: 0;
        opacity: 0.25;
        pointer-events: none;
    }

    .glow-blue {
        top: -30%;
        left: 0%;
        background: var(--gameface-blue);
        animation: float-blue 10s ease-in-out infinite alternate;
    }

    .glow-cyan {
        bottom: -20%;
        left: -15%;
        background: var(--gameface-cyan);
        animation: float-cyan 10s ease-in-out infinite alternate;
    }

    .glow-gradient {
        top: 15%;
        right: -10%;
        background: linear-gradient(
            135deg,
            var(--gameface-cyan) 15%,
            var(--gameface-blue) 100%
        );
        animation: float-mixed 10s ease-in-out infinite alternate;
    }

    @keyframes float-blue {
        50% {
            transform: translate(-5%, 5%) scale(0.9);
            opacity: 0.4;
        }

        100% {
            transform: translate(5%, 10%) scale(1.2);
            opacity: 0.3;
        }
    }

    @keyframes float-cyan {
        50% {
            transform: translate(-10%, -5%) scale(1.15);
            opacity: 0.4;
        }

        100% {
            transform: translate(5%, -10%) scale(0.9);
            opacity: 0.3;
        }
    }

    @keyframes float-mixed {
        50% {
            transform: scale(1.1);
        }

        100% {
            transform: scale(0.9);
            opacity: 0.3;
        }
    }
</style>

<div class="aurora-glow glow-blue"></div>
<div class="aurora-glow glow-cyan"></div>
<div class="aurora-glow glow-gradient"></div>
